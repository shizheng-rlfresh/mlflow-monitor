      "updated": 1773767281256,
      "link": null,
      "locked": false,
      "text": "Domain Layer  |  Done\nOwns semantic truth: Run, Timeline, Baseline, LKG, Contract, Diff, Finding, invariants, and contract-check taxonomy.\nThis layer is platform-agnostic and should not depend on MLflow.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 67,
      "containerId": null,
      "originalText": "Domain Layer  |  Done\nOwns semantic truth: Run, Timeline, Baseline, LKG, Contract, Diff, Finding, invariants, and contract-check taxonomy.\nThis layer is platform-agnostic and should not depend on MLflow.",
      "lineHeight": 1.25,
      "index": "aI",
      "frameId": null,
