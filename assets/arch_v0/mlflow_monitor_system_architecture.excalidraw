      "link": null,
      "locked": false,
      "text": "Gateway Layer  |  Partial\nOwns source-run resolution, system-owned namespace writes, sequence ordering, idempotency, LKG lookup/update, and future query support.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 43,
      "containerId": null,
      "originalText": "Gateway Layer  |  Partial\nOwns source-run resolution, system-owned namespace writes, sequence ordering, idempotency, LKG lookup/update, and future query support.",
