      "boundElements": [],
      "updated": 1773767281256,
      "link": null,
      "locked": false,
      "text": "Recipe Layer  |  Partial\nOwns recipe schema, system default, and validation. Future responsibility: compile validated recipe into a run plan consumed by workflow.",
      "fontSize": 20,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 43,
      "containerId": null,
      "originalText": "Recipe Layer  |  Partial\nOwns recipe schema, system default, and validation. Future responsibility: compile validated recipe into a run plan consumed by workflow.",
      "lineHeight": 1.25,
